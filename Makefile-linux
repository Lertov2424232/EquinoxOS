# Костыли для кросс-компиляции
CC = x86_64-elf-gcc
LD = x86_64-elf-ld
ASM = nasm

# --- ПУТИ ---
OBJ_DIR = obj
SDK_LIB_DIR = sdk/lib
ISO_ROOT = iso_root
BIN_DIR = $(ISO_ROOT)/bin

# --- ФЛАГИ ЯДРА ---
CFLAGS = -ffreestanding -O2 -Wall -Wextra -fno-exceptions -std=c11 \
         -Isrc -Isrc/system -Isrc/system/core -Isrc/syslibc -Isrc/boot/limine \
         -mcmodel=kernel -mno-red-zone -mno-mmx -mno-sse -mno-sse2 \
         -fno-stack-protector -fno-pic -g -MMD -MP

LDFLAGS = -nostdlib -T src/linker.ld -z max-page-size=0x1000
ASMFLAGS = -f elf64

# --- ФЛАГИ SDK (ДЛЯ ПРИЛОЖЕНИЙ) ---
# Добавляем -nostdinc, чтобы он не лез в /usr/include
# Добавляем -Isdk/include ПЕРВЫМ
USER_CFLAGS = -ffreestanding -nostdinc -mcmodel=small -mno-red-zone \
              -fno-stack-protector -fno-pic -g -fno-omit-frame-pointer \
              -Isdk/include -Isdk/lua -DLUA_USE_C89 -MMD -MP

# --- СПИСКИ ФАЙЛОВ ---
SRC_DIRS = src src/boot src/gui src/syslibc \
           src/system/core \
           src/system/drivers/devices/audio \
           src/system/drivers/devices/keyboard \
           src/system/drivers/devices/mouse \
           src/system/drivers/devices/pci \
           src/system/drivers/devices/pcspeaker \
           src/system/drivers/hardware/disk \
           src/system/drivers/hardware/net \
           src/system/drivers/hardware/serial \
           src/system/drivers/vesa \
           src/system/fs \
           src/system/mem \
           src/system/misc \
           src/system/shell \
           src/system/usr

# Собираем все C и ASM файлы ядра
KERNEL_C_SRCS = $(shell find src -name "*.c")
KERNEL_ASM_SRCS = $(shell find src -name "*.asm")

# Превращаем пути в объектные файлы
KERNEL_OBJS = $(patsubst src/%.c,$(OBJ_DIR)/%.o,$(KERNEL_C_SRCS)) \
              $(patsubst src/%.asm,$(OBJ_DIR)/%.o,$(KERNEL_ASM_SRCS))

# SDK и библиотеки
SDK_C_SRCS = $(wildcard $(SDK_LIB_DIR)/*.c)
SDK_ASM_SRCS = $(wildcard $(SDK_LIB_DIR)/*.asm)
SDK_OBJS = $(patsubst $(SDK_LIB_DIR)/%.c,$(SDK_LIB_DIR)/%.o,$(SDK_C_SRCS)) \
           $(patsubst $(SDK_LIB_DIR)/%.asm,$(SDK_LIB_DIR)/%.o,$(SDK_ASM_SRCS))

LUA_SRCS = $(wildcard sdk/lua/*.c)
LUA_OBJS = $(patsubst sdk/lua/%.c, $(OBJ_DIR)/lua/%.o, $(LUA_SRCS))

DOOM_SRCS = $(wildcard app/doom/*.c)
DOOM_OBJS = $(patsubst app/doom/%.c, $(OBJ_DIR)/doom/%.o, $(DOOM_SRCS))

# --- ОСНОВНЫЕ ПРАВИЛА ---

.PHONY: all setup clean run iso apps create_hdd

all: setup kernel.elf apps doom.elf create_hdd iso

setup:
	@mkdir -p $(OBJ_DIR)
	@mkdir -p $(OBJ_DIR)/lua
	@mkdir -p $(OBJ_DIR)/doom
	@mkdir -p $(BIN_DIR)
	@mkdir -p $(ISO_ROOT)/sys
	@mkdir -p $(ISO_ROOT)/res
	@mkdir -p $(ISO_ROOT)/EFI/BOOT
	@for dir in $(SRC_DIRS); do mkdir -p $(OBJ_DIR)/$${dir#src/}; done

# Сборка ядра
kernel.elf: $(KERNEL_OBJS)
	$(LD) $(LDFLAGS) $(KERNEL_OBJS) -o kernel.elf
	cp kernel.elf $(ISO_ROOT)/sys/kernel.elf

# Правило для C файлов ядра
$(OBJ_DIR)/%.o: src/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

# Правило для ASM файлов ядра
$(OBJ_DIR)/%.o: src/%.asm
	@mkdir -p $(dir $@)
	$(ASM) $(ASMFLAGS) $< -o $@

# Правило для SDK
$(SDK_LIB_DIR)/%.o: $(SDK_LIB_DIR)/%.c
	$(CC) $(USER_CFLAGS) -c $< -o $@

$(SDK_LIB_DIR)/%.o: $(SDK_LIB_DIR)/%.asm
	$(ASM) -f elf64 $< -o $@

# Правило для LUA
$(OBJ_DIR)/lua/%.o: sdk/lua/%.c
	@mkdir -p $(dir $@)
	$(CC) $(USER_CFLAGS) -c $< -o $@

# Сборка Lua CLI (тот самый фикс для stdlib.h)
sdk/lua_cli/lua.o: sdk/lua_cli/lua.c
	$(CC) $(USER_CFLAGS) -c $< -o $@

# Сборка DOOM
$(OBJ_DIR)/doom/%.o: app/doom/%.c
	@mkdir -p $(dir $@)
	$(CC) $(USER_CFLAGS) -DDOOMGENERIC_RESX=640 -DDOOMGENERIC_RESY=400 -DFEATURE_SOUND -c $< -o $@

doom.elf: $(SDK_OBJS) $(DOOM_OBJS)
	$(LD) -nostdlib -Ttext=0x1000000 -e _start $(SDK_OBJS) $(DOOM_OBJS) -o $(BIN_DIR)/doom.elf

# Сборка приложений
APP_SRCS = $(wildcard app/*.c)
APP_OBJS = $(patsubst app/%.c,app/%.o,$(APP_SRCS))
APP_ELFS = $(patsubst app/%.c,$(BIN_DIR)/%.elf,$(APP_SRCS))

apps: $(SDK_OBJS) $(LUA_OBJS) $(APP_ELFS) $(BIN_DIR)/lua.elf

# Простое правило для всех .elf в bin
$(BIN_DIR)/%.elf: app/%.o $(SDK_OBJS)
	$(LD) -nostdlib -Ttext=0x1000000 -e _start $(SDK_OBJS) $(filter-out $(SDK_OBJS), $^) -o $@

# Специальное правило для luagui (нужны либы луа)
$(BIN_DIR)/luagui.elf: app/luagui.o $(SDK_OBJS) $(LUA_OBJS)
	$(LD) -nostdlib -Ttext=0x1000000 -e _start $(SDK_OBJS) $(LUA_OBJS) app/luagui.o -o $@

# Специальное правило для lua.elf
$(BIN_DIR)/lua.elf: sdk/lua_cli/lua.o $(SDK_OBJS) $(LUA_OBJS)
	$(LD) -nostdlib -Ttext=0x1000000 -e _start $(SDK_OBJS) $(LUA_OBJS) sdk/lua_cli/lua.o -o $@

app/%.o: app/%.c
	$(CC) $(USER_CFLAGS) -c $< -o $@

# --- СИСТЕМНЫЕ ПРАВИЛА ---

clean:
	rm -rf $(OBJ_DIR)
	rm -f sdk/lib/*.o sdk/lib/*.d
	rm -f app/*.o app/*.d
	rm -f sdk/lua_cli/*.o
	rm -f kernel.elf equos.iso

create_hdd:
	@echo "--- Generating EXT2 hdd.img ---"
	python3 WINDOWS_ext2.py || python WINDOWS_ext2.py

iso:
	rm -f equos.iso
	xorriso -as mkisofs -b boot/limine/limine-bios-cd.bin \
		-no-emul-boot -boot-load-size 4 -boot-info-table \
		--efi-boot EFI/BOOT/limine-bios-cd.bin \
		-efi-boot-part --efi-boot-image \
		-o equos.iso $(ISO_ROOT)

run:
	qemu-system-x86_64 -m 512M -boot d \
		-drive file=hdd.img,format=raw,index=0,media=disk \
		-cdrom equos.iso -serial stdio \
		-device rtl8139,netdev=n0 -netdev user,id=n0 \
		-device ac97,audiodev=snd0 -audiodev pa,id=snd0 \
		-d int,guest_errors -D qemu.log

# Инклудим зависимости
-include $(KERNEL_OBJS:.o=.d)
-include $(SDK_OBJS:.o=.d)